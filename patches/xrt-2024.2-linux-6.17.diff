--- a/src/runtime_src/core/common/drv/include/xrt_cu.h
+++ b/src/runtime_src/core/common/drv/include/xrt_cu.h
@@ -22,8 +22,27 @@
 #include <linux/io.h>
 #include <linux/kthread.h>
 #include <linux/circ_buf.h>
+#include <linux/timer.h>	/* for timer_container_of / timer_delete{_sync} on 6.15+ */
 #include "kds_command.h"
 
+/* Linux 6.15 removed the legacy timer aliases:
+ *   from_timer()      -> timer_container_of()
+ *   del_timer()       -> timer_delete()
+ *   del_timer_sync()  -> timer_delete_sync()
+ * Map the old spellings so common/drv/xrt_cu.c keeps compiling. */
+#if LINUX_VERSION_CODE >= KERNEL_VERSION(6, 15, 0)
+#ifndef from_timer
+#define from_timer(var, callback_timer, timer_fieldname) \
+	timer_container_of(var, callback_timer, timer_fieldname)
+#endif
+#ifndef del_timer
+#define del_timer(t) timer_delete(t)
+#endif
+#ifndef del_timer_sync
+#define del_timer_sync(t) timer_delete_sync(t)
+#endif
+#endif
+
