+#endif
+#ifndef PFN_DEV
+#define PFN_DEV 0
+#endif
+#define phys_to_pfn_t(phys, flags) ((unsigned long)((phys) >> PAGE_SHIFT))
+#else
 #include <linux/pfn_t.h>
 #endif
