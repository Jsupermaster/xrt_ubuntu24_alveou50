+#if LINUX_VERSION_CODE >= KERNEL_VERSION(6, 16, 0)
+/* <linux/pfn_t.h> and the pfn_t type were removed in 6.16. vmf_insert_mixed()
+ * was updated to take a plain unsigned long pfn directly. Emulate the small
+ * subset of the old API surface that this file uses, so the function body
+ * downstream stays unchanged. PFN_MAP / PFN_DEV were DAX/zone hints that the
+ * core mm now handles internally; ignoring them here is safe. */
+typedef unsigned long pfn_t;
+#ifndef PFN_MAP
