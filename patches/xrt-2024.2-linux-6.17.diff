--- a/src/runtime_src/core/pcie/driver/linux/xocl/mgmtpf/Makefile
+++ b/src/runtime_src/core/pcie/driver/linux/xocl/mgmtpf/Makefile
@@ -99,6 +99,10 @@
 XILINXINCLUDE := -I$(ROOT)/../include -I$(ROOT)/../../../../include -I$(ROOT)/../../../../common/drv/include
 
 ccflags-y += $(XILINXINCLUDE) -DPF=MGMTPF
+# Linux 6.11 changed platform_driver::remove signature from int(*)(...) to void(*)(...).
+# XRT's many .remove= callbacks still return int. The kernel always ignored that return,
+# so downgrade the warning to keep compiling on 6.11+ without rewriting 60+ callbacks.
+ccflags-y += -Wno-error=incompatible-pointer-types
 ifeq ($(DEBUG),1)
 ccflags-y += -DDEBUG
 endif
--- a/src/runtime_src/core/pcie/driver/linux/xocl/subdev/p2p.c
+++ b/src/runtime_src/core/pcie/driver/linux/xocl/subdev/p2p.c
@@ -513,7 +513,18 @@
 	mb_req->req = XCL_MAILBOX_REQ_READ_P2P_BAR_ADDR;
 	mb_p2p = (struct xcl_mailbox_p2p_bar_addr *)mb_req->data;
 
+	/* If IOMMU translates this device's addresses, peer can't use raw PCI
+	 * BAR for P2P → advertise zero length so peer falls back.
+	 *
+	 * Linux 6.8 removed iommu_present(bus); the modern equivalent is the
+	 * per-device device_iommu_mapped(), which is also more accurate (the
+	 * old code asked "is any IOMMU on the bus?", but for P2P we really
+	 * care about THIS device). */
+#if LINUX_VERSION_CODE >= KERNEL_VERSION(6, 8, 0)
+	if (!device_iommu_mapped(&pcidev->dev)){
+#else
 	if (!iommu_present(&pci_bus_type)){
+#endif
 		mb_p2p->p2p_bar_len = pci_resource_len(pcidev, p2p->p2p_bar_idx);
 		mb_p2p->p2p_bar_addr = pci_resource_start(pcidev,
 				p2p->p2p_bar_idx);
--- a/src/runtime_src/core/pcie/driver/linux/xocl/subdev/ulite.c
+++ b/src/runtime_src/core/pcie/driver/linux/xocl/subdev/ulite.c
@@ -188,6 +188,35 @@
 
 static int ulite_transmit(struct uart_port *port, int stat)
 {
+#if LINUX_VERSION_CODE >= KERNEL_VERSION(6, 10, 0)
+	/* Linux 6.10 replaced uart_state::xmit (struct circ_buf) with a kfifo
+	 * embedded in tty_port (xmit_fifo). Use the new helpers; uart_fifo_out
+	 * itself updates port->icount.tx, so we don't increment it again. */
+	struct tty_port *tport = &port->state->port;
+	u8 ch;
+
+	if (stat & ULITE_STATUS_TXFULL)
+		return 0;
+
+	if (port->x_char) {
+		uart_out32(port->x_char, ULITE_TX, port);
+		port->x_char = 0;
+		port->icount.tx++;
+		return 1;
+	}
+
+	if (kfifo_is_empty(&tport->xmit_fifo) || uart_tx_stopped(port))
+		return 0;
+
+	if (!uart_fifo_out(port, &ch, 1))
+		return 0;
+	uart_out32(ch, ULITE_TX, port);
+
+	if (kfifo_len(&tport->xmit_fifo) < WAKEUP_CHARS)
+		uart_write_wakeup(port);
+
+	return 1;
+#else
 	struct circ_buf *xmit  = &port->state->xmit;
 
 	if (stat & ULITE_STATUS_TXFULL)
@@ -212,6 +241,7 @@
 		uart_write_wakeup(port);
 
 	return 1;
+#endif
 }
 
